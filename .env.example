# Banco de dados (Postgres)
POSTGRES_USER=editais
POSTGRES_PASSWORD=editais
POSTGRES_DB=central_editais

# Backend
JWT_SECRET=troque-este-segredo-em-producao
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:3000
SCRAPER_CRON=0 6 * * *

# SMTP (opcional — se vazio, os e-mails de alerta são apenas logados no console do backend)
